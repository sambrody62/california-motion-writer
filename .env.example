# Development Environment Variables

# Database
SECRET_KEY=dev-secret-key-123
LOCAL_DB_PASSWORD=test123

# Environment Settings
ENVIRONMENT=development
USE_GCP=false
USE_MOCK_LLM=false  # Set to false to use real LLM

# LLM Configuration
# Option 1: Use OpenAI
USE_OPENAI=true
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-3.5-turbo  # or gpt-4

# Option 2: Use Google Vertex AI (requires GCP credentials)
# USE_GCP=true
# USE_MOCK_LLM=false
# GOOGLE_CLOUD_PROJECT=your-gcp-project-id
# VERTEX_AI_LOCATION=us-central1

# Option 3: Use Mock LLM (for testing without API costs)
# USE_MOCK_LLM=true

# Claude runtime LLM (M2) — USE_CLAUDE=true routes drafting to Claude
USE_CLAUDE=false
ANTHROPIC_API_KEY=
CLAUDE_CHAT_MODEL=claude-haiku-4-5
CLAUDE_DRAFTING_MODEL=claude-sonnet-4-6
