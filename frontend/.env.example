# Firebase Configuration Template
# ⚠️ SECURITY WARNING: Never commit actual API keys to Git!
# Copy this file to .env.local (for development) and fill in your values
# For production, use environment variables in your CI/CD pipeline

# =============================================================================
# IMPORTANT: These values should NEVER be committed to version control
# =============================================================================

# Firebase Configuration
# Get these values from Firebase Console > Project Settings > General > Your apps > Web app
REACT_APP_FIREBASE_API_KEY=your-api-key-here
REACT_APP_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
REACT_APP_FIREBASE_PROJECT_ID=your-project-id
REACT_APP_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
REACT_APP_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
REACT_APP_FIREBASE_APP_ID=your-app-id

# Environment identifier (production, staging, development)
REACT_APP_ENVIRONMENT=development

# Backend API Configuration
REACT_APP_API_URL=http://localhost:8000/api/v1

# =============================================================================
# Security Best Practices:
# 1. Add domain restrictions to your Firebase API key in Google Cloud Console
# 2. Use different Firebase projects for dev/staging/prod
# 3. Never share or commit actual API keys
# 4. Rotate API keys regularly
# 5. Use environment variables in CI/CD, not files
# =============================================================================REACT_APP_GMAIL_ENABLED=false
